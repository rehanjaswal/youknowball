# Server-only — used by Vercel serverless proxy (api/football/[...path].js)
# Never prefix with VITE_ — keeps the key out of the browser bundle
API_FOOTBALL_KEY=your_api_football_key_here

# Local dev fallback (vite.config.js also reads API_FOOTBALL_KEY)
# Get a free key at https://www.api-football.com (100 req/day free tier)

# Data sources:
# - worldcup26.ir (proxied via /api/get/*) → live scores, standings, teams, stadiums
# - API-Football (proxied via /api/football/*) → player stats, H2H, top scorers
